---
interface Props {
  id: string;
  title: string;
  channel: string;
  duration?: string;
  thumbnailUrl?: string;
}

const { id, title, channel, duration, thumbnailUrl } = Astro.props;

// Primary thumbnail URL (maxresdefault for HD uploads)
const primaryThumbnail = thumbnailUrl || `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
// Fallback thumbnail (hqdefault always exists)
const fallbackThumbnail = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<figure class="youtube-card">
  <button
    type="button"
    class="youtube-card-button"
    data-video-id={id}
    aria-label={`Play ${title}`}
  >
    <!-- Thumbnail wrapper (16:9 aspect ratio) -->
    <div class="youtube-card-thumbnail">
      <img
        src={primaryThumbnail}
        alt={title}
        class="youtube-card-image"
        loading="lazy"
        data-fallback={fallbackThumbnail}
      />

      <!-- Play button overlay -->
      <div class="youtube-card-play-button" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="white"
        >
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>

      <!-- Duration badge (if provided) -->
      {duration && (
        <div class="youtube-card-duration" aria-hidden="true">
          {duration}
        </div>
      )}
    </div>
  </button>

  <!-- Caption -->
  <figcaption class="youtube-card-caption">
    <h3 class="youtube-card-title">{title}</h3>
    <p class="youtube-card-channel">{channel}</p>
  </figcaption>
</figure>

<style>
  /* Container */
  .youtube-card {
    margin-block: 2em;
    margin-inline: 0;
  }

  /* Button wrapper */
  .youtube-card-button {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: transform 0.4s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .youtube-card-button {
      transition: none;
    }
  }

  .youtube-card-button:hover {
    transform: scale(1.03);
  }

  .youtube-card-button:focus-visible {
    outline: 2px solid var(--brand-coral);
    outline-offset: 4px;
    border-radius: 1rem;
  }

  /* Thumbnail container (16:9 aspect ratio) */
  .youtube-card-thumbnail {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    background: var(--brand-green);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Thumbnail image */
  .youtube-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Play button overlay */
  .youtube-card-play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--brand-coral);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .youtube-card-play-button {
      transition: none;
    }
  }

  .youtube-card-button:hover .youtube-card-play-button {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 6px 40px rgba(0, 0, 0, 0.4);
  }

  /* Duration badge */
  .youtube-card-duration {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(0, 0, 0, 0.75);
    color: white;
    font-family: 'DM Sans Variable', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    pointer-events: none;
  }

  /* Caption */
  .youtube-card-caption {
    margin-top: 1rem;
  }

  .youtube-card-title {
    font-family: 'Playfair Display Variable', ui-serif, Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--brand-green);
    margin: 0 0 0.5rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .youtube-card-channel {
    font-family: 'DM Sans Variable', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin: 0;
  }

  /* Iframe after click (replaces thumbnail) */
  .youtube-card-thumbnail iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script is:inline>
  // Wait for DOM to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initYouTubeCards);
  } else {
    initYouTubeCards();
  }

  function initYouTubeCards() {
    // Handle thumbnail image fallback
    const images = document.querySelectorAll('.youtube-card-image');
    images.forEach((img) => {
      if (img instanceof HTMLImageElement) {
        img.addEventListener('error', () => {
          const fallback = img.getAttribute('data-fallback');
          if (fallback && img.src !== fallback) {
            img.src = fallback;
          }
        });
      }
    });

    // Handle click-to-play
    const buttons = document.querySelectorAll('.youtube-card-button');
    buttons.forEach((button) => {
      if (button instanceof HTMLButtonElement) {
        const videoId = button.getAttribute('data-video-id');

        // Handle click
        const playVideo = () => {
          if (!videoId) return;

          const thumbnail = button.querySelector('.youtube-card-thumbnail');
          if (!thumbnail) return;

          // Create iframe with autoplay
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
          iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
          iframe.allowFullscreen = true;
          iframe.title = button.getAttribute('aria-label') || 'YouTube video player';

          // Clear existing content safely using DOM methods
          while (thumbnail.firstChild) {
            thumbnail.removeChild(thumbnail.firstChild);
          }

          // Append iframe
          thumbnail.appendChild(iframe);
        };

        button.addEventListener('click', playVideo);
      }
    });
  }
</script>
