---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Lost? | Epic Itineraries"
  description="This page doesn't exist — but your next adventure does."
>
  <Header transparent={false} />
  <main class="pt-24">
    <section class="py-24 md:py-32">
      <div class="container max-w-2xl text-center">
        <!-- Map pin icon -->
        <div class="flex justify-center mb-8 animate-on-scroll">
          <div class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-coral/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-coral">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="m15 9-6 6"></path>
              <path d="M9 9h.01"></path>
              <path d="M15 15h.01"></path>
            </svg>
          </div>
        </div>

        <h1 class="font-serif text-4xl font-normal italic text-primary mb-4 md:text-5xl animate-on-scroll">
          You&rsquo;ve gone off the map.
        </h1>
        <p class="text-lg text-muted-foreground mb-10 animate-on-scroll">
          This page doesn&rsquo;t exist &mdash; but the best trips start with a wrong turn.
          Let&rsquo;s get you somewhere good.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 stagger-children">
          <a
            href="/"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-primary px-6 text-sm font-medium text-primary-foreground transition-all hover:bg-brand-green-light hover:scale-105 duration-200 animate-on-scroll"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Back to home
          </a>
          <a
            href="/how-it-works"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-full border border-primary/20 bg-card px-6 text-sm font-medium text-primary transition-all hover:bg-brand-cream-dark hover:scale-105 duration-200 animate-on-scroll"
          >
            See how it works
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
